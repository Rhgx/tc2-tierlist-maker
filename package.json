{
  "name": "tc2-tierlist-maker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run validate:generated && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "scrape": "tsx scripts/scraper/run.mjs all",
    "scrape:weapons": "tsx scripts/scraper/run.mjs weapons",
    "scrape:maps": "tsx scripts/scraper/run.mjs maps",
    "scrape:cosmetics": "tsx scripts/scraper/run.mjs cosmetics",
    "scrape:taunts": "tsx scripts/scraper/run.mjs taunts",
    "scrape:unusuals": "tsx scripts/scraper/run.mjs unusuals",
    "validate:generated": "tsx scripts/build/validate-generated-data.mjs"
  },
  "dependencies": {
    "@melloware/coloris": "^0.24.0",
    "gsap": "^3.12.5",
    "html-to-image": "^1.11.11",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sortablejs": "^1.15.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
